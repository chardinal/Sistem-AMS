# ============================================================
# .gitignore — Sistem AMS (Railway Hosting)
# ============================================================

# Dependensi Composer (generate ulang via composer install)
/vendor/

# Google API — JANGAN PERNAH commit ke Git!
/config/google_credentials.json
/config/google_token.json

# Environment & secrets
.env
.env.*

# Log files
*.log
logs/

# OS & IDE
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# ── File tidak perlu untuk hosting ──────────────────
# Docker (tidak dipakai di Railway)
Dockerfile
docker-compose.yml
.dockerignore

# Vercel (tidak dipakai)
vercel.json

# Setup & seeder (data sudah ada di DB)
setup.php

# Database schema (sudah di-import)
/database/

# Dokumentasi
README.md

